# =====================================================================
#  GrowthifyEdge Showcase Hub — environment example
# =====================================================================
# The app runs fully on localStorage by default (demo mode). To enable the
# optional Supabase backend, copy these values from your Supabase project
# (Dashboard → Project Settings → API).
#
# NOTE: Angular bundles config at build time, so these do NOT auto-load from a
# .env file. Use ONE of the following:
#   1) Edit src/environments/environment.prod.ts with these values, OR
#   2) Set them in your Vercel/Netlify project (then mirror into
#      environment.prod.ts via a build step), OR
#   3) For quick testing without a rebuild, set a localStorage override in the
#      browser console (see README → "Quick toggle without a rebuild").

USE_SUPABASE=true
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
SUPABASE_BUCKET=project-media
